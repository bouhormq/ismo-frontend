    "react-toastify": "^10.0.5",
    "react-tooltip": "^5.28.0",
    "recharts": "^2.12.7",
    "tailwind-merge": "^2.4.0",
    "text-clipper": "^2.2.0",
    "usehooks-ts": "^3.1.0",
    "vaul": "^0.9.1",
    "vite-tsconfig-paths": "^4.3.2",
    "wretch": "^2.11.0",
    "xlsx": "^0.18.5",
    "zod": "^3.23.8",
    "zustand": "5.0.0-rc.2"
  },
  "devDependencies": {
    "@tanstack/eslint-plugin-query": "^5.50.1",
    "@trivago/prettier-plugin-sort-imports": "^4.3.0",
    "@types/lodash": "^4.17.7",
    "@types/luxon": "^3.4.2",
    "@types/node": "^20.14.10",
